{
  "name": "galleria-principii",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev --workspace @galleria-principii/api",
    "dev:web": "npm run dev --workspace @galleria-principii/web",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:api": "npm run test --workspace @galleria-principii/api",
    "test:web": "npm run test --workspace @galleria-principii/web",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "verify": "npm run typecheck && npm run test && npm run build && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "concurrently": "^10.0.0"
  }
}
