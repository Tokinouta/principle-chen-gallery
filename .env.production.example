# Galleria Principii — production environment template.
# Copy to .env.production on the ECS host (chmod 600) and fill in real values.
# Never commit the populated file.

# --- API image (overridden by CI on each deploy) ---
API_IMAGE=crpi-8rw8lz2mj8ksyb8x.cn-beijing.personal.cr.aliyuncs.com/rarara/my-image-registry:latest

# --- API runtime ---
LOG_LEVEL=info

# --- Aliyun OSS (private media bucket) ---
ALIYUN_OSS_REGION=oss-cn-beijing
ALIYUN_OSS_BUCKET=galleria-principii-media
# ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_SIGNED_URL_TTL_SECONDS=900

# Least-privilege RAM credentials for OSS read access from the API.
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
# ALIBABA_CLOUD_SECURITY_TOKEN=

# --- Litestream replication target ---
# Bucket and key prefix where SQLite snapshots/WAL are replicated.
LITESTREAM_OSS_BUCKET=galleria-principii-backups
LITESTREAM_OSS_PATH=db/prod.db

# Separate RAM key with PutObject/GetObject on the backups bucket only.
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_ACCESS_KEY_SECRET=
