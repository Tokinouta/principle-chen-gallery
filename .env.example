# Example environment configuration for the Galleria Principii API.
# Copy to .env locally (this file is committed; .env is gitignored).
# Never commit real Aliyun credentials.

# --- Server ---
PORT=3000
HOST=127.0.0.1

# --- Database ---
# SQLite file path. Use file:./dev.db for local dev.
DATABASE_URL="file:./dev.db"

# --- Aliyun OSS (private bucket) ---
# Region and bucket are required for signing; provide real values via local .env.
ALIYUN_OSS_REGION=oss-cn-hangzhou
ALIYUN_OSS_BUCKET=galleria-principii-media
# Optional explicit endpoint; if unset, ali-oss derives it from region.
# ALIYUN_OSS_ENDPOINT=

# Aliyun RAM credentials with least-privilege OSS read permissions.
# Leave blank or unset to run the API in "offline" mode: signed URLs
# will be null and media will be marked status=unavailable.
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
# Optional STS session token (only when using temporary credentials).
# ALIBABA_CLOUD_SECURITY_TOKEN=

# Signed URL TTL in seconds. Default 900 (15 minutes).
ALIYUN_OSS_SIGNED_URL_TTL_SECONDS=900
